
{%- style -%}
  .section-{{ section.id }}-padding{
      padding-top: {{ section.settings.paddingtop | round: 0 }}px !important;
      padding-bottom: {{ section.settings.paddingbottom | round: 0 }}px !important;
    }

    @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding{
      padding-top: {{ section.settings.paddingtopmobile | round: 0 }}px !important;
      padding-bottom: {{ section.settings.paddingbottomMobile | round: 0 }}px !important;
    }
  }
{%- endstyle -%}

{% if section.blocks.size > 0 %}
 
    <div class="three-column-collection-slider  section-{{ section.id }}-padding ">
      <div class="container-1686">
         {% if section.settings.pretitle != blank or section.settings.title != blank %}
        <div
          class="top-section">
         {% if section.settings.pretitle != blank %}
                  <span class="pre-title">{{ section.settings.pretitle }}</span>
                   {% endif %}
                    {% if section.settings.title != blank %}
          <h2 class="{{section.settings.text_size}}">
            {{ section.settings.title }}

          </h2>
             {% endif %}
           
         
        </div>
         {% endif %}
              <div class="slider-outer">
   <div class="swiper js_three-column-collection-slider">
             
    <div class="swiper-wrapper">
              {%- for block in section.blocks -%}
               
                <div class=" swiper-slide ">

                    
             
                
                {% if block.settings.image != blank %}
                  {% assign imageAlt = section.settings.image.alt %}
                  {% if imageAlt == blank %}
                    {% assign imageAlt = section.settings.title %}
                  {% endif %}
                  {% include 'image_code_medium'  with  mobileImage: block.settings.image, tabletImage: block.settings.image, desktopImage: block.settings.image, imageAlt: imageAlt %}
                {% endif %}
            <div class="content">
          
                  {% if block.settings.title != blank %}
               <h3 class="h5">
                {{ block.settings.title }}
              </h3>
              {% endif %}

               {% if block.settings.buttonText != blank %}
                <a
                  class="link--primary white"
                  href="{{ block.settings.buttonLink }}"
                  title="Read More About {{ block.settings.title }}"
                  aria-label="Read More About {{ block.settings.title }}"
                >
                  {{- block.settings.buttonText -}}
                </a>
              {% endif %}
             
                </div>
                </div>
               {% endfor %}
              </div>
           

        
          
          </div>
         
             
  <div class="swiper-button-prev swiper-button-prev-collection"></div>
    <div class="swiper-button-next swiper-button-next-collection "></div>
<div class="swiper-pagination swiper-pagination-collection "></div>
          </div>
    
        
        </div>
    
        
      </div>
  {%- endif -%}


<script>

     jQuery(function() {
  var swiper = new Swiper(".js_three-column-collection-slider", {
      slidesPerView: 'auto',
      spaceBetween: 8,
      pagination: {
        el: '.swiper-pagination-collection',
        clickable: true,
      },
      navigation: {
        nextEl: ".swiper-button-next-collection",
        prevEl: ".swiper-button-prev-collection",
      },
      breakpoints: {
        601: {
          slidesPerView: 2,
          spaceBetween: 36,
        },
        1025: {
          slidesPerView: 3,
          spaceBetween: 36,
        },
      },
    });
  });
   
   
  
  </script>

{% schema %}
  {
    "name": "3 Col Collection Slider",
    "tag": "section",
    "settings": [
      {
        "type": "header",
        "content": "Slider Content"
      },
      {
        "type": "paragraph",
        "content": "Configure the heading for your three-column collection slider section. This section displays featured collections in a responsive slider that adapts beautifully across all device sizes, showing 1 column on mobile, 2 on tablet, and 3 on desktop."
      },
      {
          "type": "text",
          "id": "pretitle",
          "label": "Pretitle/Subtitle",
          "info": "Enter an optional subtitle or pre-title that appears above the main heading (e.g., 'Shop by Category', 'Featured Collections', 'Browse Our Products'). This smaller text helps create visual hierarchy and provides additional context for the collection slider."
        },
      {
        "type": "text",
        "id": "title",
        "label": "Section Title",
        "info": "Enter the main heading for the collection slider (e.g., 'Shop by Category', 'Our Collections', 'Featured Products', 'Browse Collections'). This title appears above the collection slider and should clearly communicate what type of products or categories visitors will find below."
      },
      {
        "type": "select",
        "id": "text_size",
        "label": "Title Size",
        "default": "h2",
        "info": "Choose the size of the section title. Larger sizes work well for main headings, while smaller sizes are better for subheadings or when space is limited.",
        "options": [
          {
            "value": "small",
            "label": "Small"
          }, {
            "value": "h2",
            "label": "Medium (H2)"
          }, {
            "value": "h1",
            "label": "Large (H1)"
          }
        ]
      },
     
     
      {
        "type": "header",
        "content": "Section Spacing & Layout"
      },
      {
        "type": "paragraph",
        "content": "Use these settings to control the spacing around your blog slider section. Adjust the padding to create proper visual separation from other sections on the page."
      },
      {
        "type": "range",
        "id": "paddingtop",
        "min": 0,
        "max": 140,
        "step": 2,
        "unit": "px",
        "label": "Top Spacing (Desktop)",
        "info": "Adjust the space above this section on desktop devices. Use this to create proper spacing between the blog slider and content above it.",
        "default": 0
      },
      {
        "type": "range",
        "id": "paddingtopmobile",
        "min": 0,
        "max": 100,
        "step": 2,
        "unit": "px",
        "label": "Top Spacing (Mobile)",
        "info": "Adjust the space above this section on mobile devices. Mobile spacing is typically smaller than desktop to optimize screen space.",
        "default": 0
      },
      {
        "type": "range",
        "id": "paddingbottom",
        "min": 0,
        "max": 100,
        "step": 2,
        "unit": "px",
        "label": "Bottom Spacing (Desktop)",
        "info": "Adjust the space below this section on desktop devices. Use this to create proper spacing between the blog slider and content below it.",
        "default": 0
      },
      {
        "type": "range",
        "id": "paddingbottomMobile",
        "min": 0,
        "max": 100,
        "step": 2,
        "unit": "px",
        "label": "Bottom Spacing (Mobile)",
        "info": "Adjust the space below this section on mobile devices. Mobile spacing is typically smaller than desktop to optimize screen space.",
        "default": 0
      }
      
    ],
    "blocks": [
      {
        "type": "block",
        "name": "Collection",
        "limit": 20,
        "settings": [
            {
          "type": "image_picker",
          "id": "image",
          "label": "Collection Image",
          "info": "Upload an image to represent this collection or category. This image appears as the background or main visual for the collection card in the slider. Recommended: High-quality image, minimum 800x600px, optimized for web to ensure fast loading."
     },
             {
        "type": "text",
        "id": "title",
        "label": "Collection Title",
        "info": "Enter the name or title for this collection (e.g., 'Summer Collection', 'New Arrivals', 'Sale Items', 'Best Sellers'). This text appears prominently on the collection card and should clearly identify what products or category this represents."
          },
          {
        "type": "text",
        "id": "buttonText",
        "label": "Button Text",
        "info": "Enter the text that will appear on the call-to-action button for this collection (e.g., 'Shop Now', 'View Collection', 'Browse', 'Explore'). This should be a short, action-oriented phrase that encourages visitors to explore the collection. Keep it concise and compelling."
      },
      {
        "type": "url",
        "id": "buttonLink",
        "label": "Button Link",
        "info": "Enter the URL where the button should link to when clicked. This should point to the collection page, category page, or product listing page (e.g., /collections/summer, /collections/new-arrivals, /collections/all). This button works together with the button text to provide a link to the full collection."
      }
        ]
      }
    ],
    "presets": [
      {
        "name": "Three Column Collection Slider"
      }
    ]
  }
{% endschema %}