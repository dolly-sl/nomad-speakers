{%- style -%}
  .section-{{ section.id }}-padding{
      padding-top: {{ section.settings.paddingtop | round: 0 }}px !important;
      padding-bottom: {{ section.settings.paddingbottom | round: 0 }}px !important;
    }

    @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding{
      padding-top: {{ section.settings.paddingtopmobile | round: 0 }}px !important;
      padding-bottom: {{ section.settings.paddingbottomMobile | round: 0 }}px !important;
    }
  }
{%- endstyle -%}
<div class="half-content-half-form section-{{ section.id }}-padding">
  <div class="container-1332 flex">
    <div class="content">
      <div class="ipad-none">
        <h1 class="small">{{ section.settings.content_title | default: 'Contact Us' }}</h1>
        <p>
          {{
            section.settings.content_description
            | default: 'Our customer service staff can help answer your questions. Your patronage is important to us, so please contact us!'
          }}
        </p>
      </div>
      <ul>
        <li>
          <span class="label">{{ section.settings.phone_label | default: 'Phone Orders' }}</span>
          <a href="tel:{{ section.settings.phone_number }}">
            {{- section.settings.phone_number | default: '1-844-682-2354' -}}
          </a>
        </li>

        <li>
          <span class="label">{{ section.settings.quote_label | default: 'REQUEST A QUOTE' }}</span>
          <p>{{ section.settings.quote_description | default: 'Looking to purchase for your course?' }}</p>
          {% if section.settings.quote_url != blank %}
            <a href="{{ section.settings.quote_url }}" class="link--primary green">
              {{- section.settings.quote_button_text | default: 'Get a Quote' -}}
            </a>
          {% else %}
            <a class="link--primary green">{{ section.settings.quote_button_text | default: 'Get a Quote' }}</a>
          {% endif %}
        </li>
        <li>
          <span class="label">{{ section.settings.hours_label | default: 'Hours' }}</span>
          <p>{{ section.settings.hours_text | default: '8:30am - 3:30pm PST' }}</p>
        </li>

        <li>
          <span class="label">{{ section.settings.help_label | default: 'HELP CENTER' }}</span>
          <p>
            {{
              section.settings.help_description
              | default: 'For information on returns, warranties and product problems please see our'
            }}
          </p>
          {% if section.settings.help_url != blank %}
            <a href="{{ section.settings.help_url }}" class="link--primary green">
              {{- section.settings.help_button_text | default: 'Visit Our Help Center' -}}
            </a>
          {% else %}
            <a class="link--primary green">
              {{- section.settings.help_button_text | default: 'Visit Our Help Center' -}}
            </a>
          {% endif %}
        </li>
      </ul>
    </div>

    <div class="form-section">
      <div class="ipad-block">
        <h2 class="h1 small text-center">{{ section.settings.form_title | default: 'Contact Us' }}</h2>
      </div>
      <p>
        {{
          section.settings.form_description
          | default: 'Please fill out the form below and someone will reach out to you shortly.'
        }}
      </p>
      {% form 'contact', id: 'ContactForm', class: 'contact-form' %}
        {% include 'form-status', form: form, form_id: 'ContactForm' %}
        <div class="field">
          <label for="ContactForm-name">Name</label>
          <input
            type="text"
            id="ContactForm-name"
            name="contact[name]"
            value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
            required
          >
        </div>
        <div class="field">
          <label for="ContactForm-email">Email</label>
          <input
            type="email"
            id="ContactForm-email"
            name="contact[email]"
            autocorrect="off"
            autocapitalize="off"
            value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
            required
          >
        </div>
        <div class="field">
          <label for="ContactForm-body">Message</label>
          <textarea
            id="ContactForm-body"
            name="contact[body]"
            rows="6"
            required
          >{% if form.body %}{{ form.body }}{% endif %}</textarea>
        </div>
        <button type="submit" class="btn--primary">Send</button>
      {% endform %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Half Content Half Form",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "📝 Content Settings"
    },
    {
      "type": "paragraph",
      "content": "Configure the content and contact information displayed in the left half of the section."
    },
    {
      "type": "text",
      "id": "content_title",
      "label": "Content Title",
      "default": "Contact Us"
    },
    {
      "type": "textarea",
      "id": "content_description",
      "label": "Content Description",
      "default": "Our customer service staff can help answer your questions. Your patronage is important to us, so please contact us!"
    },
    {
      "type": "header",
      "content": "📞 Contact Information"
    },
    {
      "type": "text",
      "id": "phone_label",
      "label": "Phone Label",
      "default": "Phone Orders"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone Number",
      "default": "1-844-682-2354"
    },
    {
      "type": "text",
      "id": "hours_label",
      "label": "Hours Label",
      "default": "Hours"
    },
    {
      "type": "text",
      "id": "hours_text",
      "label": "Hours Text",
      "default": "8:30am - 3:30pm PST"
    },
    {
      "type": "header",
      "content": "💬 Quote Section"
    },
    {
      "type": "text",
      "id": "quote_label",
      "label": "Quote Label",
      "default": "REQUEST A QUOTE"
    },
    {
      "type": "textarea",
      "id": "quote_description",
      "label": "Quote Description",
      "default": "Looking to purchase for your course?"
    },
    {
      "type": "text",
      "id": "quote_button_text",
      "label": "Quote Button Text",
      "default": "Get a Quote"
    },
    {
      "type": "url",
      "id": "quote_url",
      "label": "Quote URL"
    },
    {
      "type": "header",
      "content": "❓ Help Center Section"
    },
    {
      "type": "text",
      "id": "help_label",
      "label": "Help Label",
      "default": "HELP CENTER"
    },
    {
      "type": "textarea",
      "id": "help_description",
      "label": "Help Description",
      "default": "For information on returns, warranties and product problems please see our"
    },
    {
      "type": "text",
      "id": "help_button_text",
      "label": "Help Button Text",
      "default": "Visit Our Help Center"
    },
    {
      "type": "url",
      "id": "help_url",
      "label": "Help URL"
    },
    {
      "type": "header",
      "content": "📋 Form Settings"
    },
    {
      "type": "text",
      "id": "form_title",
      "label": "Form Title",
      "default": "Contact Us"
    },
    {
      "type": "textarea",
      "id": "form_description",
      "label": "Form Description",
      "default": "Please fill out the form below and someone will reach out to you shortly."
    },
    {
      "type": "header",
      "content": "📏 Section Spacing & Layout"
    },
    {
      "type": "paragraph",
      "content": "Control the vertical spacing around this full-width content section to ensure proper visual separation from other page elements on both desktop and mobile devices. Proper spacing helps your content stand out and improves readability."
    },
    {
      "type": "range",
      "id": "paddingtop",
      "min": 0,
      "max": 140,
      "step": 2,
      "unit": "px",
      "label": "Top Spacing (Desktop)",
      "info": "Adjust the space above the full-width content section on desktop devices (768px and wider). Use this to create proper visual separation from content above it, ensuring the section has adequate breathing room.",
      "default": 0
    },
    {
      "type": "range",
      "id": "paddingtopmobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Spacing (Mobile)",
      "info": "Adjust the space above the full-width content section on mobile devices (767px and smaller). Mobile spacing is typically smaller than desktop to optimize screen space while maintaining readability.",
      "default": 0
    },
    {
      "type": "range",
      "id": "paddingbottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Spacing (Desktop)",
      "info": "Adjust the space below the full-width content section on desktop devices. Use this to create proper visual separation from content below it, ensuring the section has adequate closure.",
      "default": 0
    },
    {
      "type": "range",
      "id": "paddingbottomMobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Spacing (Mobile)",
      "info": "Adjust the space below the full-width content section on mobile devices. Maintains visual hierarchy and prevents cramped layouts on smaller screens.",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Half Content Half Form",
      "category": "Content & Text"
    }
  ]
}
{% endschema %}
