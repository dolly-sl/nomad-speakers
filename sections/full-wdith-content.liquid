{%- style -%}
  .section-{{ section.id }}-padding{
      padding-top: {{ section.settings.paddingtop | round: 0 }}px !important;
      padding-bottom: {{ section.settings.paddingbottom | round: 0 }}px !important;
    }

    @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding{
      padding-top: {{ section.settings.paddingtopmobile | round: 0 }}px !important;
      padding-bottom: {{ section.settings.paddingbottomMobile | round: 0 }}px !important;
    }
  }
{%- endstyle -%}
{% if section.settings.title != blank or section.settings.description != blank %}
  <div class="full-width-content section-{{ section.id }}-padding color-{{ section.settings.color_scheme }}">
    <div class="container-1226">
      {% if section.settings.pretitle != blank %}
        <span class="pre-title">{{ section.settings.pretitle }}</span>
      {% endif %}
      {% if section.settings.title != blank %}
        <h2 class="h3">
          {{ section.settings.title }}
        </h2>
      {% endif %}
      {% comment %}
        <div class="js__description-outer">
          {% if section.settings.description != blank %}
            <div class="description full-format ">
              <h2 class="h4">{{ section.settings.description }}</h2>
            </div>
          {% endif %}
        </div>
      {% endcomment %}
      {% comment %}
        {% if section.settings.buttonText != blank %}
          <a
            href="{{ section.settings.buttonLink }}"
            title="Read More About {{ section.settings.buttonText }}"
            aria-label="Read More About {{ section.settings.buttonText }}"
            class="btn {{section.settings.button_style}}"
          >
            {{ section.settings.buttonText }}
          </a>
        {% endif %}
      {% endcomment %}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Full Width Content",
  "tag": "section",
  "class": "section-full-width-content",
  "settings": [
    {
      "type": "header",
      "content": "📝 Content Settings"
    },
    {
      "type": "paragraph",
      "content": "Create a full-width content section with optional pre-title and main heading. This section is perfect for displaying key messages, promotional content, or important announcements across the full width of the page."
    },
    {
      "type": "text",
      "id": "pretitle",
      "label": "Pre Title",
      "info": "Add an optional small label that appears above the main title (e.g., 'New', 'Featured', 'Limited Time'). This helps create visual hierarchy and draw attention to your content."
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "info": "Enter the main heading for this content section. This title will be displayed prominently and can be used to introduce key information, announcements, or promotional content."
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color Scheme",
      "options": [
        {
          "value": "white",
          "label": "White"
        },
        {
          "value": "black",
          "label": "Black"
        },
        {
          "value": "primary",
          "label": "Primary"
        },
        {
          "value": "secondary",
          "label": "Secondary"
        }
      ],
      "default": "white",
      "info": "Choose the background color scheme for this content section. This determines the overall appearance and text contrast to match your page design."
    },
    {
      "type": "header",
      "content": "📏 Section Spacing & Layout"
    },
    {
      "type": "paragraph",
      "content": "Control the vertical spacing around this full-width content section to ensure proper visual separation from other page elements on both desktop and mobile devices. Proper spacing helps your content stand out and improves readability."
    },
    {
      "type": "range",
      "id": "paddingtop",
      "min": 0,
      "max": 140,
      "step": 2,
      "unit": "px",
      "label": "Top Spacing (Desktop)",
      "info": "Adjust the space above the full-width content section on desktop devices (768px and wider). Use this to create proper visual separation from content above it, ensuring the section has adequate breathing room.",
      "default": 0
    },
    {
      "type": "range",
      "id": "paddingtopmobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Spacing (Mobile)",
      "info": "Adjust the space above the full-width content section on mobile devices (767px and smaller). Mobile spacing is typically smaller than desktop to optimize screen space while maintaining readability.",
      "default": 0
    },
    {
      "type": "range",
      "id": "paddingbottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Spacing (Desktop)",
      "info": "Adjust the space below the full-width content section on desktop devices. Use this to create proper visual separation from content below it, ensuring the section has adequate closure.",
      "default": 0
    },
    {
      "type": "range",
      "id": "paddingbottomMobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Spacing (Mobile)",
      "info": "Adjust the space below the full-width content section on mobile devices. Maintains visual hierarchy and prevents cramped layouts on smaller screens.",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Full Width Content",
      "category": "Content & Text"
    }
  ]
}
{% endschema %}
