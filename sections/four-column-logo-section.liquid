{%- style -%}
  .section-{{ section.id }}-padding{
      padding-top: {{ section.settings.paddingtop | round: 0 }}px !important;
      padding-bottom: {{ section.settings.paddingbottom | round: 0 }}px !important;
    }

    @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding{
      padding-top: {{ section.settings.paddingtopmobile | round: 0 }}px !important;
      padding-bottom: {{ section.settings.paddingbottomMobile | round: 0 }}px !important;
    }
  }
{%- endstyle -%}
<div class="four-column-logo-section section-{{ section.id }}-padding color-{{ section.settings.color_scheme }}">
  <div class="container-1590">
    {% if section.settings.preTitle != blank %}
      <span class="pre-title">{{ section.settings.preTitle }}</span>
    {% endif %}
    <ul class="logos flex">
      {% for block in section.blocks %}
        {% if block.settings.image != blank %}
          <li>
            <div class="image-section">
              {% assign imageAlt = block.settings.image.alt %}
              {% if imageAlt == blank %}
                {% assign imageAlt = block.settings.pretitle %}
              {% endif %}
              {% if imageAlt == blank %}
                {% assign imageAlt = shop.name %}
              {% endif %}
              {% include 'image_code'  with  mobileImage: block.settings.image, tabletImage: block.settings.image, desktopImage: block.settings.image, imageAlt: imageAlt %}
            </div>
          </li>
        {% endif %}
      {% endfor %}
    </ul>
  </div>
</div>
{% schema %}
{
  "name": "Four Column Logo",
  "settings": [
    {
      "type": "header",
      "content": "📝 Content Settings"
    },
    {
      "type": "paragraph",
      "content": "Configure the section header and visual appearance. This section displays up to 4 logos in a horizontal row, perfect for showcasing brand partnerships, certifications, or featured organizations."
    },
    {
      "type": "text",
      "id": "preTitle",
      "label": "Pre Title",
      "info": "Enter a small optional label that appears above the logos (e.g., 'Trusted By', 'Partners', 'Featured Brands'). This helps set context for the logo display."
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color Scheme",
      "options": [
        {
          "value": "white",
          "label": "White"
        },
        {
          "value": "black",
          "label": "Black"
        },
        {
          "value": "primary",
          "label": "Primary"
        },
        {
          "value": "secondary",
          "label": "Secondary"
        }
      ],
      "default": "white",
      "info": "Choose the background color scheme for the logo section. This determines the overall appearance and contrast of the section to match your page design."
    },
    {
      "type": "header",
      "content": "📏 Section Spacing & Layout"
    },
    {
      "type": "paragraph",
      "content": "Control the vertical spacing around this logo section to ensure proper visual separation from other page elements on both desktop and mobile devices."
    },
    {
      "type": "range",
      "id": "paddingtop",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top Spacing (Desktop)",
      "info": "Adjust the space above the logo section on desktop devices. Use this to create proper visual separation from content above it.",
      "default": 0
    },
    {
      "type": "range",
      "id": "paddingtopmobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Spacing (Mobile)",
      "info": "Adjust the space above this section on mobile devices. Mobile spacing is typically smaller than desktop to optimize screen space.",
      "default": 0
    },
    {
      "type": "range",
      "id": "paddingbottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Bottom Spacing (Desktop)",
      "info": "Adjust the space below the logo section on desktop devices. Use this to create proper visual separation from content below it.",
      "default": 0
    },
    {
      "type": "range",
      "id": "paddingbottomMobile",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom Spacing (Mobile)",
      "info": "Adjust the space below this section on mobile devices. Mobile spacing is typically smaller than desktop to optimize screen space.",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "limit": 4,

      "settings": [
        {
          "type": "header",
          "content": "Logo Configuration"
        },
        {
          "type": "paragraph",
          "content": "Upload logo images to display in this four-column layout. You can add up to 4 logos that will be shown side-by-side. Perfect for displaying brand partnerships, certifications, or featured organizations."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo Image",
          "info": "Upload the logo image for this column. The logo should be clear, recognizable, and properly sized. Recommended size: 80x80px to 150x150px for optimal display quality across all devices."
        },
        {
          "type": "url",
          "id": "imageLink",
          "label": "Logo Link URL",
          "info": "Enter an optional URL where the logo should link to (e.g., partner website, certification page). Leave blank if the logo should not be clickable."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Four Column Logo Section",
      "category": "Brand & Features"
    }
  ]
}
{% endschema %}
