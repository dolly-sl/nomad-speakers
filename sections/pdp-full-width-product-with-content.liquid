{%- style -%}
  .section-{{ section.id }}-padding{
      padding-top: {{ section.settings.paddingtop | round: 0 }}px !important;
      padding-bottom: {{ section.settings.paddingbottom | round: 0 }}px !important;
    }

    @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding{
      padding-top: {{ section.settings.paddingtopmobile | round: 0 }}px !important;
      padding-bottom: {{ section.settings.paddingbottomMobile | round: 0 }}px !important;
    }
  }
{%- endstyle -%}
{% if section.settings.product != blank %}
  <div class="tabs-with-products section-{{ section.id }}-padding">
     <div class="container-1590">
   
     
     
      <div class="tabs">
         
           
        <div
              class="tab-content text-center js-tab-content"
             
            >
 {% if section.settings.subtitle != blank %}
              <p class="pre-title text-center">{{ section.settings.subtitle }}</p>
                  {% endif %}
               {% if section.settings.title != blank %}
              <h2 class="small text-center">{{ section.settings.title }}</h2>
                  {% endif %}
 
  {% if section.settings.image != blank %}
                  <div class="image-section">

         {% assign imageAlt = section.settings.image.alt %}
      {% if imageAlt == blank %}
        {% assign imageAlt = section.settings.title %}
      {% endif %}
        {% include 'image_code'  with  mobileImage: section.settings.mobileImage, tabletImage: section.settings.image, desktopImage: section.settings.image, imageAlt: imageAlt %}
       
        
      </div>
    {% endif %}

      {% if section.settings.point1 != blank or section.settings.point2 != blank or section.settings.point2 != blank or section.settings.point4 != blank %}
        <ul class="points ipad-block">
          {% if section.settings.point1 != blank %}
          <li class="pre-title">{{ section.settings.point1 }}</li>
          {% endif %}
          {% if section.settings.point2 != blank %}
          <li class="pre-title">{{ section.settings.point2 }}</li>
          {% endif %}      
          {% if section.settings.point3 != blank %}
          <li class="pre-title">{{ section.settings.point3 }}</li>
          {% endif %}
          {% if section.settings.point4 != blank %}
          <li class="pre-title">{{ section.settings.point4 }}</li>
          {% endif %}
        </ul> 
         {% endif %}

            

              {% if section.settings.product != blank %}
            
                {% assign productRelated = all_products[section.settings.product] %}
             {% assign selected_variant = productRelated.selected_or_first_available_variant | default: productRelated.variants.first %}
 

                {% if productRelated %}
                   <div class="product-btns">
                  {% if productRelated.available %}
                   <a href="javascript:;" class="btn btn--primary js__card-add-to-cart" title="Add {{ productRelated.title}} to Cart"
                 data-product-id="{{ productRelated.id }}" 
                 data-variant-id="{{ selected_variant.id }}">
                {{ section.settings.buttonText | default: "Add to Cart" }}
              </a>
                {% endif %}
              
              </div>
              {% endif %}
              
           {% endif %}

         
                  
           




            
            
             
      </div>
    </div>
  
      

     </div> 
  

   
  </div>
{% endif %}

{% schema %}
{
  "name": "PDP Full width product",
  "settings": [
    {
        "type": "header",
        "content": "📦 Product Selection"
      },
      {
          "type": "product",
          "id": "product",
          "label": "Product to Display",
          "info": "Select the product that will be featured in this full-width product section. This product will be displayed with an add-to-cart button."
        },
    {
        "type": "header",
        "content": "📝 Section Content Settings"
      },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Optional Subtitle / Pre-Title",
          "info": "Add a small prefix text that appears above the main title (e.g., 'Featured Product', 'New Arrival', 'Best Seller'). This helps categorize the product section."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Section Title / Headline",
          "info": "Enter the main heading for this product section. This will be displayed prominently and should clearly communicate what the product is or highlight key benefits."
        },
    {
        "type": "header",
        "content": "🖼️ Product Image Settings"
      },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop Product Image",
          "info": "Upload a high-quality product image for desktop/laptop screens. This will be the main visual element of the product section. Recommended size: 1200px or wider."
        },
        {
          "type": "image_picker",
          "id": "mobileImage",
          "label": "Mobile Product Image",
          "info": "Upload a mobile-optimized product image for smartphone devices. This should be optimized for mobile viewing and may have different dimensions. If left blank, the desktop image will be used on mobile. Recommended size: 720px or smaller."
        },
    {
        "type": "header",
        "content": "✅ Key Features / Bullet Points"
      },
        {
          "type": "text",
          "id": "point1",
          "label": "Feature Point 1",
          "info": "Enter the first key feature or selling point for this product (e.g., 'Free Shipping', '2 Year Warranty', 'Easy Installation'). Leave blank to hide this point."
        },
         {
          "type": "text",
          "id": "point2",
          "label": "Feature Point 2",
          "info": "Enter the second key feature or selling point for this product. Leave blank to hide this point."
        },
        {
          "type": "text",
          "id": "point3",
          "label": "Feature Point 3",
          "info": "Enter the third key feature or selling point for this product. Leave blank to hide this point."
        },
         {
          "type": "text",
          "id": "point4",
          "label": "Feature Point 4",
          "info": "Enter the fourth key feature or selling point for this product. Leave blank to hide this point."
        },
    {
        "type": "header",
        "content": "🔘 Add-to-Cart Button"
      },
         {
      "type": "text", 
      "id": "buttonText",
      "label": "Button Label / Text",
      "info": "The text displayed on the add-to-cart button (e.g., 'Add to Cart', 'Buy Now', 'Add to Bag'). If left blank, 'Add to Cart' will be used as the default text."
     },
    {
        "type": "header",
        "content": "📏 Section Spacing & Layout Controls"
      },
      {
        "type": "paragraph",
        "content": "Control the vertical spacing around this product section to ensure proper visual separation from other content. Adjust these values to create appropriate breathing room and maintain consistent page rhythm."
      },
      {
        "type": "range",
        "id": "paddingtop",
        "min": 0,
        "max": 140,
        "step": 2,
        "unit": "px",
        "label": "Desktop - Top Padding",
        "info": "Distance from the top edge on desktop/laptop screens (0-140px). Increase to add more space above the section or decrease for a tighter layout.",
        "default": 0
      },
      {
        "type": "range",
        "id": "paddingtopmobile",
        "min": 0,
        "max": 100,
        "step": 2,
        "unit": "px",
        "label": "Mobile - Top Padding",
        "info": "Distance from the top edge on mobile devices (0-100px). Mobile values are typically lower than desktop to maximize screen space while maintaining readability.",
        "default": 0
      },
      {
        "type": "range",
        "id": "paddingbottom",
        "min": 0,
        "max": 100,
        "step": 2,
        "unit": "px",
        "label": "Desktop - Bottom Padding",
        "info": "Distance to the bottom edge on desktop/laptop screens (0-100px). Prevents the section from sitting too close to content below it.",
        "default": 0
      },
      {
        "type": "range",
        "id": "paddingbottomMobile",
        "min": 0,
        "max": 100,
        "step": 2,
        "unit": "px",
        "label": "Mobile - Bottom Padding",
        "info": "Distance to the bottom edge on mobile devices (0-100px). Optimize for touch-friendly scrolling and visual flow on smaller screens.",
        "default": 0
      }
     
      
  ],
  "presets": [
    {
      "name": "PDP Full width product with content"
    }
  ]
}
{% endschema %}
