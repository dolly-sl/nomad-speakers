
{%- style -%}
  .section-{{ section.id }}-padding{
      padding-top: {{ section.settings.paddingtop | round: 0 }}px !important;
      padding-bottom: {{ section.settings.paddingbottom | round: 0 }}px !important;
    }

    @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding{
      padding-top: {{ section.settings.paddingtopmobile | round: 0 }}px !important;
      padding-bottom: {{ section.settings.paddingbottomMobile | round: 0 }}px !important;
    }
  }
{%- endstyle -%}

{% if section.blocks.size > 0 %}
  {% if section.settings.title != blank %}
    <div class="three-column-blog  section-{{ section.id }}-padding ">
      <div class="container-1590">
        <div
          class="top-section">
          <h2 class="medium">
            {{ section.settings.title }}

          </h2>
           
          {% if section.settings.buttonText != blank %}
            <a
              class="link--primary"   href="{{ section.settings.buttonLink }}"
              title="Read More About {{ section.settings.title }}"
              aria-label="Read More About {{ section.settings.title }}"
            >
              {{- section.settings.buttonText -}}
            </a>
          {% endif %}

        </div>
        
              <ul class="flex-wrap">

              {%- for block in section.blocks -%}
                {% assign articleRelated = block.settings.article %}
                <li class="articlecard--outer ">
                  {%
                    include 'article_Card' with articleRelated: articleRelated
                    , show_tags: true
                    , show_title: true
                    , show_shortdescription: true
                    , show_readMore: true
                  %}
                </li>
              {%- endfor -%}
              </ul>
           

        
          
          </div>
         
              
       
    
        
      </div>
  {%- endif -%}
{%- endif -%}


{% schema %}
  {
    "name": "Three Column Blog",
    "tag": "section",
     "max_blocks": 3,
    "settings": [
      {
        "type": "header",
        "content": "Blog Section Content"
      },
      {
        "type": "paragraph",
        "content": "Configure the heading for your three-column blog section. This section displays up to 3 featured blog posts in a responsive grid layout that looks great on desktop, tablet, and mobile devices."
      },
      {
        "type": "text",
        "id": "title",
        "label": "Section Title",
        "info": "Enter the main heading for the blog section (e.g., 'Latest Blog Posts', 'Featured Articles', 'From Our Blog', 'News & Updates'). This title appears above the blog post cards and should clearly communicate what type of content visitors will find below."
      },
     
      {
        "type": "header",
        "content": "Call-to-Action Button"
      },
      {
        "type": "paragraph",
        "content": "Add an optional call-to-action button above the blog cards to encourage visitors to explore more blog content. This provides a clear path for readers who want to see all your blog posts or visit your main blog page."
      },
      {
        "type": "text",
        "id": "buttonText",
        "label": "Button Text",
        "info": "Enter the text that will appear on the call-to-action button (e.g., 'View All Posts', 'Read More Articles', 'Browse Blog', 'See All'). This should be a short, action-oriented phrase that clearly communicates what visitors will find when they click. Keep it concise and compelling."
      },
      {
        "type": "url",
        "id": "buttonLink",
        "label": "Button Link",
        "info": "Enter the URL where the button should link to. This could be your main blog page (/blogs/news), a specific blog category or tag, or any other relevant page you want to direct visitors to. This button only appears if button text is also provided."
      },
      
      {
        "type": "header",
        "content": "Section Spacing & Layout"
      },
      {
        "type": "paragraph",
        "content": "Use these settings to control the spacing around your blog slider section. Adjust the padding to create proper visual separation from other sections on the page."
      },
      {
        "type": "range",
        "id": "paddingtop",
        "min": 0,
        "max": 140,
        "step": 2,
        "unit": "px",
        "label": "Top Spacing (Desktop)",
        "info": "Adjust the space above this section on desktop devices. Use this to create proper spacing between the blog slider and content above it.",
        "default": 0
      },
      {
        "type": "range",
        "id": "paddingtopmobile",
        "min": 0,
        "max": 100,
        "step": 2,
        "unit": "px",
        "label": "Top Spacing (Mobile)",
        "info": "Adjust the space above this section on mobile devices. Mobile spacing is typically smaller than desktop to optimize screen space.",
        "default": 0
      },
      {
        "type": "range",
        "id": "paddingbottom",
        "min": 0,
        "max": 100,
        "step": 2,
        "unit": "px",
        "label": "Bottom Spacing (Desktop)",
        "info": "Adjust the space below this section on desktop devices. Use this to create proper spacing between the blog slider and content below it.",
        "default": 0
      },
      {
        "type": "range",
        "id": "paddingbottomMobile",
        "min": 0,
        "max": 100,
        "step": 2,
        "unit": "px",
        "label": "Bottom Spacing (Mobile)",
        "info": "Adjust the space below this section on mobile devices. Mobile spacing is typically smaller than desktop to optimize screen space.",
        "default": 0
      }
      
    ],
    "blocks": [
      {
        "type": "block",
        "name": "Blog Article",
        "limit": 3,
        "settings": [
          {
            "type": "header",
            "content": "Article Selection"
          },
          {
            "type": "paragraph",
            "content": "Select the specific blog article you want to feature in this column. Each article block creates one card in the three-column blog section. You can add up to 3 article blocks total."
          },
          {
            "type": "article",
            "id": "article",
            "label": "Select Article",
            "info": "Choose a blog article from your store's blog to display in this column. The article card will automatically display its featured image, title, publication date, excerpt, and a read more link. For best visual results, ensure the article has an engaging featured image and a compelling excerpt or summary. This section supports up to 3 articles total."
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Three Column Blog"
      }
    ]
  }
{% endschema %}