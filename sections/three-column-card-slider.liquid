<div class="three-column-card-slider">
    <div class="container-1328">
        <div class="heading">
            <span class="pre-title">{{ section.settings.pre_title }}</span>
            <h2>{{ section.settings.title }}</h2>
            {% if section.settings.buttonText != blank %}
              <a
                class="btn--primary"
                href="{{ section.settings.buttonLink }}"
                title="Read More About {{ section.settings.title }}"
                aria-label="Read More About {{ section.settings.title }}"
              >
                {{- section.settings.buttonText -}}
              </a>
            {% endif %}
        </div>
        <div class="slider-outer">
             <div class="swiper js_three-column-card-slider">
          <div class="swiper-wrapper">
            {% for block in section.blocks %}
                <div class="swiper-slide card">
                   <div class="image-section">
                        {% if block.settings.image != blank %}
                            <img src="{{ block.settings.image | img_url: '804' }}" alt="{{ block.settings.title }}" class="three-column-card-slider__image">
                        {% endif %}
                        </div>
                        <h3 class="h6">{{ block.settings.title }}</h3>
                       {% if block.settings.buttonText != blank %}
              <a
                class="btn--secondary"
                href="{{ block.settings.buttonLink }}"
                title="Read More About {{ block.settings.title }}"
                aria-label="Read More About {{ block.settings.title }}"
              >
                {{- block.settings.buttonText -}}
              </a>
            {% endif %}
                   
                </div>
            {% endfor %}
            </div>
             <div class="swiper-button-prev swiper-button-prev-three-column-card"></div>
        <div class="swiper-button-next swiper-button-next-three-column-card "></div>
        <div class="swiper-pagination swiper-pagination-three-column-card "></div>
            </div>
        </div>
        </div>
        </div>
