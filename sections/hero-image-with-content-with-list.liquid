{%- liquid
  assign kit_count = 0
  for block in section.blocks
    if block.type == 'kit_card'
      assign kit_count = kit_count | plus: 1
    endif
  endfor
-%}
{% if section.settings.video != blank or section.settings.image != blank or section.settings.title != blank or section.settings.pretitle != blank or kit_count > 0 %}
  <section class="hero-image-with-content-with-list align-{{ section.settings.content_alignment }}">
    <div class="outer">
      <div class="image-section ">
        {% if section.settings.video != blank %}
          {{
            section.settings.video
            | video_tag:
              image_size: '1920x',
              loop: true,
              autoplay: true,
              controls: false,
              muted: true,
              alt: section.settings.title
          }}
        {% elsif section.settings.image != blank %}
          {% assign imageAlt = section.settings.image.alt | default: section.settings.title %}
          {% include 'image_code' with mobileImage: section.settings.mobileImage, tabletImage: section.settings.mobileImage, desktopImage: section.settings.image, imageAlt: imageAlt, critical: true %}
        {% endif %}
      </div>
      <div class="container-1124 flex">
        <div class="content">
          {% if section.settings.pretitle != blank %}
            <span class="pre-title-bold">{{ section.settings.pretitle }}</span>
          {% endif %}

          {% if section.settings.title != blank %}
            <h2 class="{{ section.settings.text_size }}">{{ section.settings.title }}</h2>
          {% endif %}

          {% if section.settings.description != blank %}
            <div class="description full-format">
              {{ section.settings.description }}
            </div>
          {% endif %}

          {% if section.settings.buttonText != blank and section.settings.buttonLink != blank %}
            <a
              class="btn btn--secondary{% if section.settings.button_show_arrow %} hero-image-with-content-with-list__btn--with-arrow{% endif %}"
              href="{{ section.settings.buttonLink }}"
              title="{{ section.settings.buttonText | escape }}"
              aria-label="{{ section.settings.buttonText | escape }}"
              {% if section.settings.button_opens_lity_modal %}data-lity{% endif %}
            >
              <span class="hero-image-with-content-with-list__btn-text">{{ section.settings.buttonText }}</span>
              {% if section.settings.button_show_arrow %}
                <span class="hero-image-with-content-with-list__btn-icon" aria-hidden="true">
                  <img
                    src="{{ 'icon-arrow-black.svg' | asset_url }}"
                    width="14"
                    height="12"
                    alt=""
                    loading="lazy"
                  >
                </span>
              {% endif %}
            </a>
          {% endif %}
        </div>
      </div>
    </div>

    {% if kit_count > 0 %}
      <div class="container-1124 hero-image-with-content-with-list__kits">
        <div class="hero-image-with-content-with-list__kits-grid">
          {% for block in section.blocks %}
            {% if block.type == 'kit_card' %}
              <article class="hero-image-with-content-with-list__kit" {{ block.shopify_attributes }}>
                {% if block.settings.image != blank %}
                  <div class="hero-image-with-content-with-list__kit-media">
                    {%- assign kit_img_alt = block.settings.image.alt | default: block.settings.title -%}
                    {{
                      block.settings.image
                      | image_url: width: 900
                      | image_tag:
                        loading: 'lazy',
                        widths: '300,450,600,750,900',
                        sizes: '(min-width: 900px) 42vw, 90vw',
                        alt: kit_img_alt
                    }}
                  </div>
                {% endif %}

                {% if block.settings.title != blank %}
                  <h3 class="hero-image-with-content-with-list__kit-heading">{{ block.settings.title | escape }}</h3>
                {% endif %}

                {% if block.settings.description != blank %}
                  <div class="hero-image-with-content-with-list__kit-description rte">
                    {{ block.settings.description }}
                  </div>
                {% endif %}

                {% if block.settings.description != blank and block.settings.bullet_list != blank %}
                  <hr class="hero-image-with-content-with-list__kit-rule">
                {% elsif block.settings.description == blank and block.settings.bullet_list != blank %}
                  <hr class="hero-image-with-content-with-list__kit-rule">
                {% endif %}

                {% if block.settings.bullet_list != blank %}
                  <div class="hero-image-with-content-with-list__kit-list rte">
                    {{ block.settings.bullet_list }}
                  </div>
                {% endif %}
              </article>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </section>
{% endif %}

{% schema %}
{
  "name": "Hero image content list",
  "tag": "section",
  "class": "section hero-image-with-content-section",
  "settings": [
    {
      "type": "header",
      "content": "Background image or video"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Background video",
      "info": "If set, video is shown instead of images. Autoplays muted in a loop."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobileImage",
      "label": "Mobile image"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "text_size",
      "label": "Title size",
      "default": "h1",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ]
    },
    {
      "type": "text",
      "id": "pretitle",
      "label": "Pretitle",
      "default": "CHOOSE YOUR POWER SETUP"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Two ways to power your setup"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "buttonText",
      "label": "Button text",
      "default": "BUILD MY NOMAD"
    },
    {
      "type": "url",
      "id": "buttonLink",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "button_show_arrow",
      "label": "Show arrow icon on button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "button_opens_lity_modal",
      "label": "Open button link in video lightbox (Lity)",
      "default": false,
      "info": "Adds data-lity. Use a YouTube, Vimeo, or direct video file URL as the button link."
    }
  ],
  "blocks": [
    {
      "type": "kit_card",
      "name": "Comparison card",
      "limit": 2,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Kit title"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "richtext",
          "id": "bullet_list",
          "label": "Bullet list",
          "info": "Use the bullet list controls in the editor."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero image content list",
      "blocks": [
        {
          "type": "kit_card",
          "settings": {
            "title": "Hardwired Kit",
            "description": "<p>Best for riders who want a permanent, always-ready setup with continuous power every time they ride.</p>",
            "bullet_list": "<ul><li>Wires direct to battery on gas or electric carts</li><li>Works with batteries from 12-60V</li><li>Clean integrated install</li></ul>"
          }
        },
        {
          "type": "kit_card",
          "settings": {
            "title": "Rechargeable Kit",
            "description": "<p>Best for riders who want the simplest install possible. Charge Nomad just like a phone or tablet via USB-C</p>",
            "bullet_list": "<ul><li>No wiring needed</li><li>Fastest install</li><li>Great for flexibility</li></ul>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
