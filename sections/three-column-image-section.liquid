{%- style -%}
  .section-{{ section.id }}-padding{
      padding-top: {{ section.settings.paddingtop | round: 0 }}px !important;
      padding-bottom: {{ section.settings.paddingbottom | round: 0 }}px !important;
    }

    @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding{
      padding-top: {{ section.settings.paddingtopmobile | round: 0 }}px !important;
      padding-bottom: {{ section.settings.paddingbottomMobile | round: 0 }}px !important;
    }
  }
{%- endstyle -%}
<div class="three-column-image-section section-{{ section.id }}-padding color-{{ section.settings.color_scheme }}">
  <div class="container-1590">
    <ul class="columns flex">
      {% for block in section.blocks %}
        {% if block.settings.image != blank %}
          <li>
            <div class="image-section">
              {% assign imageAlt = block.settings.image.alt %}
              {% if imageAlt == blank %}
                {% assign imageAlt = block.settings.pretitle %}
              {% endif %}
              {% if imageAlt == blank %}
                {% assign imageAlt = shop.name %}
              {% endif %}
              {% include 'image_code'  with  mobileImage: block.settings.image, tabletImage: block.settings.image, desktopImage: block.settings.image, imageAlt: imageAlt %}
            </div>
          </li>
        {% endif %}
      {% endfor %}
    </ul>
  </div>
</div>
{% schema %}
{
  "name": "Three Column Image",
  "max_blocks": 3,
  "settings": [
    {
      "type": "header",
      "content": "Section Spacing & Layout"
    },
    {
      "type": "paragraph",
      "content": "Control the vertical spacing around your three-column image section. Adjust the padding values to create proper visual separation from other content sections and ensure optimal layout on both desktop and mobile devices. This section displays up to 3 images in a responsive grid layout."
    },
    {
      "type": "range",
      "id": "paddingtop",
      "min": 0,
      "max": 140,
      "step": 2,
      "unit": "px",
      "label": "Top Spacing (Desktop)",
      "info": "Adjust the space above this section on desktop devices. Use this to create proper spacing between the three-column section and content above it.",
      "default": 0
    },
    {
      "type": "range",
      "id": "paddingtopmobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Spacing (Mobile)",
      "info": "Adjust the space above this section on mobile devices. Mobile spacing is typically smaller than desktop to optimize screen space.",
      "default": 0
    },
    {
      "type": "range",
      "id": "paddingbottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Spacing (Desktop)",
      "info": "Adjust the space below this section on desktop devices. Use this to create proper spacing between the three-column section and content below it.",
      "default": 0
    },
    {
      "type": "range",
      "id": "paddingbottomMobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Spacing (Mobile)",
      "info": "Adjust the space below this section on mobile devices. Mobile spacing is typically smaller than desktop to optimize screen space.",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image Column",
      "limit": 3,
      "settings": [
        {
          "type": "header",
          "content": "Column Content"
        },
        {
          "type": "paragraph",
          "content": "Upload an image for this column in the three-column image section. Each column displays a single image, and you can add up to 3 columns total. These images will be displayed side-by-side in a responsive grid that adapts to different screen sizes."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Column Image",
          "info": "Upload an image to display in this column. This can be a product image, logo, icon, or any visual that fits your design. The image will be automatically resized to fit the column layout. For best results, use high-quality images that are optimized for web (recommended: 600x800px or similar aspect ratio)."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Three Column Image Section"
    }
  ]
}
{% endschema %}
