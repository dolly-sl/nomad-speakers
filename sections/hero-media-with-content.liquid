{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.paddingtop | round: 0 }}px !important;
    padding-bottom: {{ section.settings.paddingbottom | round: 0 }}px !important;
  }

  @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.paddingtopmobile | round: 0 }}px !important;
      padding-bottom: {{ section.settings.paddingbottomMobile | round: 0 }}px !important;
    }
  }
{%- endstyle -%}

{% if section.blocks.size > 0 %}
  <section class="hero-media-with-content section-{{ section.id }}-padding color-{{ section.settings.color_scheme }}">
    <div class="swiper js_hero-media-with-content-slider">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          {% if block.type == 'slide' %}
            <div class="swiper-slide align-{{ block.settings.content_alignment }}" {{ block.shopify_attributes }}>
              <div class="hero-media-with-content__media">
                {% if block.settings.image != blank %}
                  {% assign imageAlt = block.settings.image.alt | default: block.settings.title %}
                  {% include 'image_code' with mobileImage: block.settings.mobileImage, tabletImage: block.settings.mobileImage, desktopImage: block.settings.image, imageAlt: imageAlt, critical: true %}
                {% endif %}
              </div>

              <div class="hero-media-with-content__content container-1328">
                {% if block.settings.pretitle != blank %}
                  <span class="pre-title">{{ block.settings.pretitle }}</span>
                {% endif %}

                {% if block.settings.title != blank %}
                  <h1 class="{{ block.settings.text_size }}">{{ block.settings.title }}</h1>
                {% endif %}

                {% if block.settings.description != blank %}
                  <div class="description">
                    {{ block.settings.description }}
                  </div>
                {% endif %}

                {% if block.settings.buttonText != blank and block.settings.buttonLink != blank %}
                  <div class="buttons">
                    <a class="btn btn--primary" href="{{ block.settings.buttonLink }}">
                      {{- block.settings.buttonText -}}
                    </a>
                  </div>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% if section.blocks.size > 1 %}
        <div class="swiper-button-prev swiper-button-prev-hero-media"></div>
        <div class="swiper-button-next swiper-button-next-hero-media"></div>
       
      {% endif %}
    </div>
  </section>
{% endif %}

<script>
  jQuery(function () {
    if (jQuery('.js_hero-media-with-content-slider').length) {
      new Swiper('.js_hero-media-with-content-slider', {
        slidesPerView: 1,
        loop: {{ section.settings.slider_loop }},
        navigation: {
          nextEl: '.swiper-button-next-hero-media',
          prevEl: '.swiper-button-prev-hero-media',
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Hero Media Content",
  "tag": "section",
  "class": "section hero-media-with-content-section",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "dark",
      "options": [
        { "value": "dark", "label": "Dark" },
        { "value": "light", "label": "Light" }
      ]
    },
    {
      "type": "select",
      "id": "slider_loop",
      "label": "Loop slides",
      "default": "true",
      "options": [
        { "value": "true", "label": "On" },
        { "value": "false", "label": "Off" }
      ]
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "paddingtop",
      "min": 0,
      "max": 140,
      "step": 2,
      "unit": "px",
      "label": "Top spacing (desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "paddingtopmobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top spacing (mobile)",
      "default": 0
    },
    {
      "type": "range",
      "id": "paddingbottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Bottom spacing (desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "paddingbottomMobile",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom spacing (mobile)",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 10,
      "settings": [
        {
          "type": "header",
          "content": "Background image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "mobileImage",
          "label": "Mobile image"
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "select",
          "id": "content_alignment",
          "label": "Content alignment",
          "default": "left",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ]
        },
        {
          "type": "select",
          "id": "text_size",
          "label": "Title size",
          "default": "h1",
          "options": [
            { "value": "h1", "label": "H1" },
            { "value": "h2", "label": "H2" },
            { "value": "h3", "label": "H3" }
          ]
        },
        {
          "type": "text",
          "id": "pretitle",
          "label": "Pretitle"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "buttonText",
          "label": "Button text",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "buttonLink",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Media Content",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}

