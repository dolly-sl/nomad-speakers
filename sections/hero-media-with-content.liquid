{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.paddingtop | round: 0 }}px !important;
    padding-bottom: {{ section.settings.paddingbottom | round: 0 }}px !important;
  }

  @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.paddingtopmobile | round: 0 }}px !important;
      padding-bottom: {{ section.settings.paddingbottomMobile | round: 0 }}px !important;
    }
  }
{%- endstyle -%}

<section
  class="hero-media-with-content section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} align-{{ section.settings.content_alignment }}"
>
  <div class="hero-media-with-content__media">
    {% if section.settings.video != blank %}
      {{
        section.settings.video
        | video_tag:
          image_size: '2400x',
          loop: true,
          autoplay: true,
          controls: false,
          muted: true,
          alt: section.settings.title
      }}
    {% elsif section.settings.image != blank %}
      {% assign imageAlt = section.settings.image.alt | default: section.settings.title %}
      {% include 'image_code' with mobileImage: section.settings.mobileImage, tabletImage: section.settings.mobileImage, desktopImage: section.settings.image, imageAlt: imageAlt, critical: true %}
    {% endif %}
  </div>

  <div class="hero-media-with-content__content container-1328">
    {% if section.settings.pretitle != blank %}
      <span class="pre-title">{{ section.settings.pretitle }}</span>
    {% endif %}

    {% if section.settings.title != blank %}
      <h1 class="{{ section.settings.text_size }}">{{ section.settings.title }}</h1>
    {% endif %}

    {% if section.settings.description != blank %}
      <div class="description">
        {{ section.settings.description }}
      </div>
    {% endif %}

    {% if section.settings.buttonText != blank and section.settings.buttonLink != blank %}
      <div class="buttons">
        <a class="btn btn--primary" href="{{ section.settings.buttonLink }}">
          {{- section.settings.buttonText -}}
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero Media Content",
  "tag": "section",
  "class": "section hero-media-with-content-section",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "dark",
      "options": [
        { "value": "dark", "label": "Dark" },
        { "value": "light", "label": "Light" }
      ]
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "text_size",
      "label": "Title size",
      "default": "h1",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ]
    },
    {
      "type": "header",
      "content": "Background media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobileImage",
      "label": "Mobile image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Background video (autoplay)",
      "info": "If set, the video shows instead of images. It autoplays, loops, and is muted."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "pretitle",
      "label": "Pretitle"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Stream Your Favorite App Anywhere With HI-FI Audio"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "buttonText",
      "label": "Button 1 text",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "buttonLink",
      "label": "Button 1 link"
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "paddingtop",
      "min": 0,
      "max": 140,
      "step": 2,
      "unit": "px",
      "label": "Top spacing (desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "paddingtopmobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top spacing (mobile)",
      "default": 0
    },
    {
      "type": "range",
      "id": "paddingbottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Bottom spacing (desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "paddingbottomMobile",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom spacing (mobile)",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Hero Media Content"
    }
  ]
}
{% endschema %}

