{%- style -%}
  .section-{{ section.id }}-padding{
      padding-top: {{ section.settings.paddingtop | round: 0 }}px !important;
      padding-bottom: {{ section.settings.paddingbottom | round: 0 }}px !important;
    }

    @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding{
      padding-top: {{ section.settings.paddingtopmobile | round: 0 }}px !important;
      padding-bottom: {{ section.settings.paddingbottomMobile | round: 0 }}px !important;
    }
  }
{%- endstyle -%}
{% if section.blocks.size > 0 %}
  <div class="two-column-card section-{{ section.id }}-padding ">
    <div class="container-1280">
      <div class="heading">
        <span class="pre-title">{{ section.settings.pretitle }}</span>
        <h2>{{ section.settings.title }}</h2>
        {% if section.settings.button_text != blank %}
          <a
            class="btn btn--secondary"
            href="{{ section.settings.button_link }}"
            title="Read More About {{ section.settings.title }}"
            aria-label="Read More About {{ section.settings.title }}"
          >
            {{- section.settings.button_text -}}
          </a>
        {% endif %}
      </div>
   
   
          <ul class="cards">
            {% for block in section.blocks %}
              <li>
                <div class="image-section">
                  
                  
                  {% assign imageAlt = block.settings.image.alt %}
                  {% if imageAlt == blank %}
                    {% assign imageAlt = block.settings.title %}
                  {% endif %}

                  {% if block.settings.image != blank %}
                    {% include 'image_code_small' with mobileImage: block.settings.image, tabletImage: block.settings.image, desktopImage: block.settings.image, imageAlt: imageAlt %}
                  {% endif %}
                </div>
                <h3 class="h5">{{ block.settings.title }}</h3>
                  {% if block.settings.description != blank %}
          <div class="description">{{ block.settings.description }}</div>
        {% endif %}

         {% if block.settings.bullet_list != blank %}
          <div class="bullet_list full-format small">{{ block.settings.bullet_list }}</div>
        {% endif %}
              </li>
            {% endfor %}
          </ul>
         </div>
   
  </div>
{%- endif -%}


{% schema %}
{
  "name": "Two Column Card",
  "tag": "section",
  "settings": [
     
    {
      "type": "header",
      "content": "Heading"
    },
     {
      "type": "text",
      "id": "pretitle",
      "label": "Pretitle",
      "default": "CHOOSE YOUR POWER SETUP"
    },
  {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Two ways to power your setup"
    },
    
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "BUILD MY NOMAD"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
        "type": "header",
        "content": "Section Spacing & Layout"
      },
      {
        "type": "paragraph",
        "content": "Use these settings to control the spacing around your blog slider section. Adjust the padding to create proper visual separation from other sections on the page."
      },
      {
        "type": "range",
        "id": "paddingtop",
        "min": 0,
        "max": 140,
        "step": 2,
        "unit": "px",
        "label": "Top Spacing (Desktop)",
        "info": "Adjust the space above this section on desktop devices. Use this to create proper spacing between the blog slider and content above it.",
        "default": 0
      },
      {
        "type": "range",
        "id": "paddingtopmobile",
        "min": 0,
        "max": 100,
        "step": 2,
        "unit": "px",
        "label": "Top Spacing (Mobile)",
        "info": "Adjust the space above this section on mobile devices. Mobile spacing is typically smaller than desktop to optimize screen space.",
        "default": 0
      },
      {
        "type": "range",
        "id": "paddingbottom",
        "min": 0,
        "max": 100,
        "step": 2,
        "unit": "px",
        "label": "Bottom Spacing (Desktop)",
        "info": "Adjust the space below this section on desktop devices. Use this to create proper spacing between the blog slider and content below it.",
        "default": 0
      },
      {
        "type": "range",
        "id": "paddingbottomMobile",
        "min": 0,
        "max": 100,
        "step": 2,
        "unit": "px",
        "label": "Bottom Spacing (Mobile)",
        "info": "Adjust the space below this section on mobile devices. Mobile spacing is typically smaller than desktop to optimize screen space.",
        "default": 0
      }
    
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "limit": 2,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "richtext",
          "id": "bullet_list",
          "label": "Bullet list",
          "info": "Use the bullet list controls in the editor."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Two Column Card",
      
    }
  ]
}
{% endschema %}
