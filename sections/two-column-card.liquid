


{% schema %}
{
  "name": "Two Column Card",
  "tag": "section",
  "settings": [
     
    {
      "type": "header",
      "content": "Heading"
    },
     {
      "type": "text",
      "id": "pretitle",
      "label": "Pretitle",
      "default": "CHOOSE YOUR POWER SETUP"
    },
  {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Two ways to power your setup"
    },
    
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "BUILD MY NOMAD"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
    
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "limit": 2,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "richtext",
          "id": "bullet_list",
          "label": "Bullet list",
          "info": "Use the bullet list controls in the editor."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Two Column Card",
      
    }
  ]
}
{% endschema %}
