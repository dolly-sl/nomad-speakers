{%- style -%}
  .section-{{ section.id }}-padding{
      padding-top: {{ section.settings.paddingtop | round: 0 }}px !important;
      padding-bottom: {{ section.settings.paddingbottom | round: 0 }}px !important;
    }

    @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding{
      padding-top: {{ section.settings.paddingtopmobile | round: 0 }}px !important;
      padding-bottom: {{ section.settings.paddingbottomMobile | round: 0 }}px !important;
    }
  }
{%- endstyle -%}
{% if section.blocks.size > 0 %}
  <div class="half-image-half-content-outer section-{{ section.id }}-padding  {{ section.settings.media_position }}">
    <div class="container-1448">
      {% if section.settings.title != blank %}
        <div class="heading-block text-center">
          <span class="pre-title">{{ section.settings.pretitleSection }}</span>
          <h2>{{ section.settings.title }}</h2>
        </div>
      {% endif %}
      {%- for block in section.blocks -%}
        {% if block.settings.image != blank %}
          <div class="half-image-half-content flex-wrap">
            <div
              class="content  {% if block.settings.image == blank %} full {% endif %}"
              data-aos="fade-up"
              data-aos-duration="2000"
            >
              {% if block.settings.pretitle != blank %}
                <span class="pre-title">{{ block.settings.pretitle }}</span>
              {% endif %}
              <h2 class="{{ block.settings.text_size }}">
                {{ block.settings.title }}
              </h2>

              {% if block.settings.description != blank %}
                <div class="description full-format ">
                  {{ block.settings.description }}
                </div>
              {% endif %}

              {% if block.settings.buttonText != blank %}
                <a
                  class="btn {{block.settings.button_style}}"
                  href="{{ block.settings.buttonLink }}"
                  title="Read More About {{ block.settings.title }}"
                  aria-label="Read More About {{ block.settings.title }}"
                >
                  {{- block.settings.buttonText -}}
                </a>
              {% endif %}
            </div>
            {% if block.settings.image != blank or block.settings.video != blank %}
              <div class="image-section ">
                {% if block.settings.media_type == 'video' and block.settings.video != blank %}
                  <div class="video-container">
                    {{
                      block.settings.video
                      | video_tag: image_size: '1100x', loop: true, autoplay: true, controls: false, muted: true
                    }}
                  </div>
                {% elsif block.settings.image != blank %}
                  {% assign imageAlt = section.settings.image.alt %}
                  {% if imageAlt == blank %}
                    {% assign imageAlt = section.settings.title %}
                  {% endif %}
                  {% include 'image_code_medium'  with  mobileImage: block.settings.image, tabletImage: block.settings.image, desktopImage: block.settings.image, imageAlt: imageAlt %}
                {% endif %}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Half Image Half Content",
  "tag": "section",
  "class": "section-half-image-half-content",
  "settings": [
    {
      "type": "header",
      "content": "📋 Section Header Settings"
    },
    {
      "type": "text",
      "id": "pretitleSection",
      "label": "Optional Section Pre-Title",
      "info": "Add a small prefix text that appears above the main section title (e.g., 'Our Services', 'Featured', 'Discover'). This helps categorize the entire section and provides additional context."
    },
    {
      "type": "text",
      "id": "title",
      "label": "Main Section Title",
      "info": "Enter the primary heading for this section. This appears at the top and introduces the content blocks below. Make it descriptive and engaging."
    },
    {
      "type": "select",
      "id": "media_position",
      "label": "Image/Video Position",
      "info": "Controls where the media (image or video) appears relative to the text content. Left places media on the left side, Right places media on the right side. This affects the visual flow and layout balance.",
      "options": [
        {
          "value": "left",
          "label": "Left Side"
        },
        {
          "value": "right",
          "label": "Right Side"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "📏 Section Spacing & Layout Controls"
    },
    {
      "type": "paragraph",
      "content": "Control the vertical spacing around this split-content section to ensure proper visual separation from other content. Adjust these values to create appropriate breathing room and maintain consistent page rhythm."
    },
    {
      "type": "range",
      "id": "paddingtop",
      "min": 0,
      "max": 140,
      "step": 2,
      "unit": "px",
      "label": "Desktop - Top Padding",
      "info": "Distance from the top edge on desktop/laptop screens (0-140px). Increase to add more space above the section or decrease for a tighter layout.",
      "default": 0
    },
    {
      "type": "range",
      "id": "paddingtopmobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile - Top Padding",
      "info": "Distance from the top edge on mobile devices (0-100px). Mobile values are typically lower than desktop to maximize screen space while maintaining readability.",
      "default": 0
    },
    {
      "type": "range",
      "id": "paddingbottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Desktop - Bottom Padding",
      "info": "Distance to the bottom edge on desktop/laptop screens (0-100px). Prevents the section from sitting too close to content below it.",
      "default": 0
    },
    {
      "type": "range",
      "id": "paddingbottomMobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile - Bottom Padding",
      "info": "Distance to the bottom edge on mobile devices (0-100px). Optimize for touch-friendly scrolling and visual flow on smaller screens.",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "Section",
      "name": "Split Content Block",
      "limit": 10,
      "settings": [
        {
          "type": "header",
          "content": "🖼️ Media Content (Image or Video)"
        },
        {
          "type": "select",
          "id": "media_type",
          "label": "Media Type Selection",
          "info": "Choose whether to display a static image or an animated video in this content block. Videos will autoplay, loop continuously, and be muted by default for optimal user experience.",
          "options": [
            {
              "value": "image",
              "label": "Static Image"
            },
            {
              "value": "video",
              "label": "Autoplay Video"
            }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Content Image",
          "info": "Upload an image to display alongside the text content in a split-screen layout (half image, half content). This image appears on one side based on your Media Position setting. Recommended size: 1350 x 1000px for optimal display."
        },
        {
          "type": "video",
          "id": "video",
          "label": "Content Video File",
          "info": "Upload a video file in MP4, WebM, or OGG format. The video will automatically play, loop continuously, and be muted by default for a seamless user experience. Keep file sizes optimized for faster loading."
        },
        {
          "type": "header",
          "content": "📝 Text Content Settings"
        },
        {
          "type": "text",
          "id": "pretitle",
          "label": "Optional Pre-Title / Subtitle",
          "info": "Add a small prefix text that appears above the main title for this content block (e.g., 'Feature 1', 'New', 'Premium'). This helps create visual hierarchy and adds context."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Content Heading / Title",
          "info": "Enter the main heading for this content block. This will be displayed prominently alongside the media. Make it descriptive and engaging to grab attention."
        },
        {
          "type": "select",
          "id": "text_size",
          "label": "Heading Size / Typography",
          "info": "Controls the visual prominence of the heading. H3 (Large) for main points, Medium for balanced emphasis, H4 (Small) for sub-points or when you want a more subtle presence.",
          "default": "h4",
          "options": [
            {
              "value": "h4",
              "label": "Small - H4 Heading"
            },
            {
              "value": "medium",
              "label": "Medium - Balanced"
            },
            {
              "value": "h3",
              "label": "Large - H3 Heading"
            }
          ]
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Content Description / Body Text",
          "info": "Add detailed content for this block. Use rich text formatting to create paragraphs, add bullet points, emphasize key information, or include links. Perfect for explaining features, benefits, or providing additional context."
        },
        {
          "type": "header",
          "content": "🔘 Call-to-Action Button (Optional)"
        },
        {
          "type": "text",
          "id": "buttonText",
          "label": "Button Label / Text",
          "info": "The clickable text displayed on the button (e.g., 'Learn More', 'Shop Now', 'Get Started'). Leave blank to completely hide the button from this content block."
        },
        {
          "type": "url",
          "id": "buttonLink",
          "label": "Button Destination URL",
          "info": "The web address where users will be directed when they click the button. Can link to product pages, collections, custom pages, external sites, or anchor links."
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Visual Style / Button Type",
          "info": "Controls the button's appearance. Primary (bold and high-contrast) for main actions, Secondary (subtle) for less prominent actions, Underline (minimal) for text-like links.",
          "options": [
            {
              "value": "btn--primary",
              "label": "Primary Button (Bold)"
            },
            {
              "value": "btn--secondary",
              "label": "Secondary Button (Subtle)"
            },
            {
              "value": "btn--tertiary",
              "label": "Underline Button (Minimal)"
            }
          ],
          "default": "btn--primary"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Half Image Half Content",
      "blocks": [
        {
          "type": "Section"
        }
      ]
    }
  ]
}
{% endschema %}
