    "custom_liquid_NYNVYh": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "custom_liquid": "<section class=\"nomad-install-section\">\n  <div class=\"nomad-install-inner\">\n    \n    <!-- LEFT 9:16 VIDEO -->\n    <div class=\"nomad-install-video-wrap\">\n      <video\n        class=\"nomad-install-video\"\n        autoplay\n        muted\n        loop\n        playsinline\n      >\n        <source src=\"https://cdn.shopify.com/videos/c/o/v/b3b92ad7809b4a2d97fb0b6580b7e89b.mp4\" type=\"video/mp4\">\n      </video>\n    </div>\n\n    <!-- RIGHT CONTENT -->\n    <div class=\"nomad-install-content\">\n      <p class=\"nomad-install-eyebrow\">\n        DRILL 4 HOLES. TIGHTEN 4 SCREWS. THAT’S IT.\n      </p>\n\n      <h2 class=\"nomad-install-heading\">\n        Installs in 30 minutes or less\n      </h2>\n\n      <p class=\"nomad-install-copy\">\n        The CADDYBAR™ × Nomad setup was designed to be simple and straightforward,\n        so you can spend less time installing and more time enjoying your cart.\n      </p>\n\n      <a href=\"#install-video\" class=\"nomad-install-button\">\n        WATCH NOW\n        <span>→</span>\n      </a>\n    </div>\n\n  </div>\n\n  <!-- BOTTOM FEATURE BAR -->\n  <div class=\"nomad-install-feature-bar\">\n    <div class=\"nomad-install-feature\">\n      <span class=\"nomad-check\">✓</span>\n      <span>SIMPLE MOUNTING PROCESS</span>\n    </div>\n\n    <div class=\"nomad-install-feature\">\n      <span class=\"nomad-check\">✓</span>\n      <span>NO COMPLICATED FABRICATION</span>\n    </div>\n\n    <div class=\"nomad-install-feature\">\n      <span class=\"nomad-check\">✓</span>\n      <span>STEP-BY-STEP INSTRUCTIONS</span>\n    </div>\n\n    <div class=\"nomad-install-feature\">\n      <span class=\"nomad-check\">✓</span>\n      <span>VIDEO INSTALL TUTORIAL</span>\n    </div>\n  </div>\n</section>\n\n<style>\n  .nomad-install-section {\n    width: 100%;\n    background: #101112;\n    color: #fff;\n    padding: 80px 5vw 56px;\n    overflow: hidden;\n  }\n\n  .nomad-install-inner {\n    max-width: 1180px;\n    margin: 0 auto;\n    display: grid;\n    grid-template-columns: minmax(260px, 390px) minmax(320px, 520px);\n    gap: 80px;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .nomad-install-video-wrap {\n    width: 100%;\n    aspect-ratio: 9 / 16;\n    border-radius: 24px;\n    overflow: hidden;\n    background: #000;\n    box-shadow: 0 26px 80px rgba(0, 0, 0, 0.45);\n  }\n\n  .nomad-install-video {\n    width: 100%;\n    height: 100%;\n    display: block;\n    object-fit: cover;\n  }\n\n  .nomad-install-content {\n    max-width: 540px;\n  }\n\n  .nomad-install-eyebrow {\n    margin: 0 0 12px;\n    font-size: 12px;\n    line-height: 1.2;\n    letter-spacing: 0.08em;\n    font-weight: 800;\n    color: #ecec35;\n    text-transform: uppercase;\n  }\n\n  .nomad-install-heading {\n    margin: 0 0 16px;\n    font-size: clamp(40px, 4.4vw, 68px);\n    line-height: 0.95;\n    letter-spacing: -0.055em;\n    font-weight: 800;\n    color: #fff;\n  }\n\n  .nomad-install-copy {\n    margin: 0 0 30px;\n    max-width: 470px;\n    font-size: 16px;\n    line-height: 1.55;\n    font-weight: 500;\n    color: rgba(255, 255, 255, 0.86);\n  }\n\n  .nomad-install-button {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    gap: 18px;\n    min-height: 56px;\n    padding: 0 28px;\n    border-radius: 999px;\n    background: #efef37;\n    color: #111;\n    text-decoration: none;\n    font-size: 12px;\n    letter-spacing: 0.04em;\n    font-weight: 900;\n    transition: transform 0.2s ease, background 0.2s ease;\n  }\n\n  .nomad-install-button:hover {\n    transform: translateY(-2px);\n    background: #ffff45;\n  }\n\n  .nomad-install-button span {\n    font-size: 18px;\n    line-height: 1;\n  }\n\n  .nomad-install-feature-bar {\n    max-width: 960px;\n    width: 100%;\n    margin: 70px auto 0;\n    padding: 24px 28px;\n    border-radius: 10px;\n    background: rgba(255, 255, 255, 0.06);\n    backdrop-filter: blur(12px);\n    -webkit-backdrop-filter: blur(12px);\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 24px;\n  }\n\n  .nomad-install-feature {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    font-size: 11px;\n    line-height: 1.2;\n    letter-spacing: 0.04em;\n    font-weight: 800;\n    color: #fff;\n    text-transform: uppercase;\n    white-space: nowrap;\n  }\n\n  .nomad-check {\n    width: 22px;\n    height: 22px;\n    min-width: 22px;\n    border: 1px solid rgba(239, 239, 55, 0.75);\n    border-radius: 999px;\n    color: #efef37;\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 12px;\n    line-height: 1;\n  }\n\n  @media screen and (max-width: 990px) {\n    .nomad-install-section {\n      padding: 56px 22px 36px;\n    }\n\n    .nomad-install-inner {\n      grid-template-columns: 1fr;\n      gap: 36px;\n      max-width: 680px;\n    }\n\n    .nomad-install-video-wrap {\n      max-width: 390px;\n      margin: 0 auto;\n    }\n\n    .nomad-install-content {\n      text-align: center;\n      margin: 0 auto;\n    }\n\n    .nomad-install-copy {\n      margin-left: auto;\n      margin-right: auto;\n    }\n\n    .nomad-install-feature-bar {\n      margin-top: 42px;\n      grid-template-columns: repeat(2, 1fr);\n      gap: 18px 20px;\n      padding: 22px;\n    }\n\n    .nomad-install-feature {\n      white-space: normal;\n    }\n  }\n\n  @media screen and (max-width: 600px) {\n  .nomad-install-section {\n    padding: 0 0 30px;\n    background: #101112;\n  }\n\n  .nomad-install-inner {\n    max-width: none;\n    width: 100%;\n    gap: 0;\n  }\n\n  .nomad-install-video-wrap {\n    width: 100%;\n    max-width: none;\n    aspect-ratio: 9 / 16;\n    height: auto;\n    border-radius: 0;\n    box-shadow: none;\n    margin: 0;\n    overflow: hidden;\n  }\n\n  .nomad-install-video {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n  }\n\n  .nomad-install-content {\n    padding: 34px 18px 0;\n    text-align: left;\n    max-width: none;\n  }\n\n  .nomad-install-heading {\n    font-size: 42px;\n    line-height: 0.98;\n  }\n\n  .nomad-install-copy {\n    font-size: 14px;\n    line-height: 1.5;\n    margin-left: 0;\n    margin-right: 0;\n  }\n\n  .nomad-install-button {\n    min-height: 52px;\n    padding: 0 24px;\n  }\n\n  .nomad-install-feature-bar {\n    width: calc(100% - 32px);\n    grid-template-columns: 1fr;\n    margin: 34px 16px 0;\n    padding: 18px;\n    border-radius: 10px;\n  }\n\n  .nomad-install-feature {\n    font-size: 10px;\n  }\n}",
        "paddingtop": 0,
        "paddingtopmobile": 0,
        "paddingbottom": 0,
        "paddingbottomMobile": 0
      }
