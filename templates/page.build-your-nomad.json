\n  .nb-guide-copy {\n    padding: 18px;\n  }\n\n  .nb-guide-top {\n    display: flex;\n    justify-content: space-between;\n    gap: 12px;\n    align-items: flex-start;\n    margin-bottom: 8px;\n  }\n\n  .nb-guide-top h3 {\n    margin: 0;\n    font-size: 21px;\n    line-height: 1.1;\n    letter-spacing: -0.015em;\n    font-weight: 800;\n    color: #1b1b1d;\n  }\n\n  .nb-guide-top span {\n    flex-shrink: 0;\n    background: #f2ff19;\n    color: #1b1b1d;\n    border-radius: 999px;\n    padding: 6px 9px;\n    font-size: 10px;\n    line-height: 1;\n    font-weight: 900;\n    text-transform: uppercase;\n  }\n\n  .nb-guide-copy p {\n    margin: 0 0 14px;\n    font-size: 14px;\n    line-height: 1.5;\n    color: #55565a;\n  }\n\n  .nb-tags {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 6px;\n  }\n\n  .nb-tags span {\n    display: inline-flex;\n    align-items: center;\n    min-height: 26px;\n    padding: 0 9px;\n    border-radius: 999px;\n    background: #ffffff;\n    color: #1b1b1d;\n    font-size: 11px;\n    line-height: 1;\n    font-weight: 800;\n  }\n\n  .nb-mount-options {\n    display: grid;\n    gap: 10px;\n  }\n\n  .nb-mount-option {\n    display: grid;\n    grid-template-columns: 1fr auto;\n    gap: 16px;\n    align-items: center;\n    background: #ffffff;\n    border: 1px solid rgba(0,0,0,0.16);\n    border-radius: 14px;\n    padding: 16px;\n  }\n\n  .nb-mount-option.active {\n    border: 2px solid #1b1b1d;\n    box-shadow: 0 0 0 3px rgba(242,255,25,0.55);\n  }\n\n  .nb-mount-option-copy strong {\n    display: block;\n    font-size: 17px;\n    line-height: 1.15;\n    font-weight: 800;\n    color: #1b1b1d;\n  }\n\n  .nb-mount-option-copy small {\n    display: block;\n    margin-top: 5px;\n    font-size: 13px;\n    line-height: 1.4;\n    color: #55565a;\n  }\n\n  .nb-qty {\n    display: grid;\n    grid-template-columns: 34px 42px 34px;\n    align-items: center;\n    border: 1px solid rgba(0,0,0,0.18);\n    border-radius: 999px;\n    overflow: hidden;\n    background: #f6f6f7;\n  }\n\n  .nb-qty-btn {\n    width: 34px;\n    height: 34px;\n    border: 0;\n    background: transparent;\n    color: #1b1b1d;\n    font-size: 18px;\n    font-weight: 900;\n    cursor: pointer;\n  }\n\n  .nb-qty input {\n    width: 42px;\n    height: 34px;\n    border: 0;\n    background: transparent;\n    text-align: center;\n    font-size: 14px;\n    font-weight: 800;\n    color: #1b1b1d;\n    -moz-appearance: textfield;\n  }\n\n  .nb-qty input::-webkit-outer-spin-button,\n  .nb-qty input::-webkit-inner-spin-button {\n    -webkit-appearance: none;\n    margin: 0;\n  }\n\n  .nb-addons {\n    display: grid;\n    gap: 10px;\n  }\n\n  .nb-addon {\n    display: grid;\n    grid-template-columns: auto 1fr auto;\n    gap: 12px;\n    align-items: center;\n    background: #ffffff;\n    border: 1px solid rgba(0,0,0,0.16);\n    border-radius: 14px;\n    padding: 16px;\n    cursor: pointer;\n  }\n\n  .nb-addon.active {\n    border: 2px solid #1b1b1d;\n    box-shadow: 0 0 0 3px rgba(242,255,25,0.55);\n  }\n\n  .nb-addon input {\n    width: 20px;\n    height: 20px;\n    accent-color: #1b1b1d;\n  }\n\n  .nb-addon strong {\n    display: block;\n    font-size: 16px;\n    line-height: 1.15;\n    font-weight: 800;\n    color: #1b1b1d;\n  }\n\n  .nb-addon small {\n    display: block;\n    margin-top: 4px;\n    font-size: 13px;\n    line-height: 1.35;\n    color: #55565a;\n  }\n\n  .nb-addon em {\n    font-style: normal;\n    font-size: 14px;\n    font-weight: 800;\n    color: #1b1b1d;\n  }\n\n  .nb-summary {\n    position: sticky;\n    bottom: 18px;\n    background: #1b1b1d;\n    color: #ffffff;\n    border-radius: 20px;\n    padding: 20px;\n    box-shadow: 0 18px 50px rgba(0,0,0,0.24);\n  }\n\n  .nb-summary h3 {\n    margin: 0 0 10px;\n    font-size: 20px;\n    line-height: 1.1;\n    font-weight: 800;\n    color: #ffffff;\n  }\n\n  .nb-summary ul {\n    list-style: none;\n    padding: 0;\n    margin: 0 0 16px;\n    display: grid;\n    gap: 6px;\n  }\n\n  .nb-summary li {\n    display: flex;\n    justify-content: space-between;\n    gap: 12px;\n    font-size: 13px;\n    line-height: 1.3;\n    color: rgba(255,255,255,0.78);\n  }\n\n  .nb-summary li strong {\n    color: #ffffff;\n  }\n\n  .nb-summary li .included {\n    color: #f2ff19;\n    font-weight: 900;\n  }\n\n  .nb-price-row,\n  .nb-discount-row {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    gap: 12px;\n    border-top: 1px solid rgba(255,255,255,0.18);\n    padding-top: 12px;\n    margin-top: 12px;\n    font-size: 15px;\n    color: #ffffff;\n  }\n\n  .nb-price-row strong,\n  .nb-discount-row strong {\n    font-size: 18px;\n    color: #ffffff;\n  }\n\n  .nb-discount-row,\n  .nb-discount-row strong {\n    color: #f2ff19;\n  }\n\n  .nb-cart-button {\n    width: 100%;\n    min-height: 56px;\n    margin-top: 16px;\n    border: 0;\n    border-radius: 999px;\n    background: #f2ff19;\n    color: #1b1b1d;\n    font-size: 16px;\n    font-weight: 900;\n    cursor: pointer;\n  }\n\n  .nb-cart-button:disabled {\n    opacity: 0.7;\n    cursor: not-allowed;\n  }\n\n  .nb-note {\n    margin: 10px 0 0;\n    font-size: 12px;\n    line-height: 1.35;\n    color: rgba(255,255,255,0.66);\n    text-align: center;\n  }\n\n  @media screen and (max-width: 960px) {\n    .nb-layout {\n      grid-template-columns: 1fr;\n    }\n\n    .nb-preview {\n      position: relative;\n      top: auto;\n    }\n\n    .nb-preview-card {\n      min-height: auto;\n    }\n\n    .nb-summary {\n      position: relative;\n      bottom: auto;\n    }\n  }\n\n  @media screen and (max-width: 760px) {\n    .nb-guide {\n      padding: 22px 16px;\n      border-radius: 20px;\n    }\n\n    .nb-guide-grid,\n    .nb-guide-grid-two {\n      grid-template-columns: 1fr;\n    }\n\n    .nb-guide-heading h2 {\n      font-size: 34px;\n    }\n\n    .nb-guide-image {\n      aspect-ratio: 16 / 11;\n    }\n\n    .nb-guide-top {\n      flex-direction: column;\n      gap: 8px;\n    }\n\n    .nb-guide-top span {\n      width: fit-content;\n    }\n  }\n\n  @media screen and (max-width: 600px) {\n    .nomad-builder {\n      padding: 34px 14px 54px;\n    }\n\n    .nb-header {\n      margin-bottom: 28px;\n    }\n\n    .nb-header h1 {\n      font-size: 46px;\n      line-height: 0.98;\n    }\n\n    .nb-header p:not(.nb-kicker) {\n      font-size: 15px;\n    }\n\n    .nb-preview-card {\n      border-radius: 22px;\n      padding: 28px;\n    }\n\n    .nb-preview-copy {\n      border-radius: 18px;\n      padding: 20px;\n    }\n\n    .nb-panel {\n      border-radius: 22px;\n      padding: 18px;\n    }\n\n    .nb-options-two,\n    .nb-presets {\n      grid-template-columns: 1fr;\n    }\n\n    .nb-option,\n    .nb-preset {\n      padding: 16px;\n    }\n\n    .nb-option.active,\n    .nb-preset.active {\n      padding: 15px;\n    }\n\n    .nb-step-title h3 {\n      font-size: 20px;\n    }\n\n    .nb-mount-option {\n      grid-template-columns: 1fr;\n    }\n\n    .nb-qty {\n      width: fit-content;\n    }\n\n    .nb-addon {\n      grid-template-columns: auto 1fr;\n    }\n\n    .nb-addon em {\n      grid-column: 2;\n    }\n  }\n</style>\n\n<script>\n  (function () {\n    const state = {\n      preset: 'starter',\n      discountCode: ''\n    };\n\n    const presetRules = {\n      starter: {\n        addons: [],\n        discount: '',\n        discountLabel: '',\n        discountValue: ''\n      },\n      performance: {\n        addons: ['battery'],\n        discount: 'NOMADPERFORMANCE',\n        discountLabel: 'Performance discount',\n        discountValue: '-$20'\n      },\n      complete: {\n        addons: ['battery', 'case'],\n        discount: 'NOMADCOMPLETE',\n        discountLabel: 'Complete setup discount',\n        discountValue: '-$40'\n      }\n    };\n\n    const colorButtons = document.querySelectorAll('[data-type=\"color\"]');\n    const includedMountButtons = document.querySelectorAll('[data-type=\"included-mount\"]');\n    const presetButtons = document.querySelectorAll('.nb-preset');\n    const includedMountGuideCards = document.querySelectorAll('[data-select-included-mount]');\n    const premiumMountRows = document.querySelectorAll('[data-premium-row]');\n    const addonInputs = document.querySelectorAll('.nb-addon input');\n    const addonGuideCards = document.querySelectorAll('[data-toggle-addon]');\n\n    const summaryList = document.getElementById('nb-summary-list');\n    const subtotalEl = document.getElementById('nb-subtotal');\n    const discountRow = document.getElementById('nb-discount-row');\n    const discountLabel = document.getElementById('nb-discount-label');\n    const discountValue = document.getElementById('nb-discount-value');\n    const addToCartBtn = document.getElementById('nb-add-to-cart');\n    const mainImage = document.getElementById('nb-main-image');\n\n    function money(value) {\n      return '$' + Number(value).toFixed(0);\n    }\n\n    function getActiveColor() {\n      return document.querySelector('.nb-option.active[data-type=\"color\"]');\n    }\n\n    function getActiveIncludedMount() {\n      return document.querySelector('.nb-option.active[data-type=\"included-mount\"]');\n    }\n\n    function setActive(buttons, clicked) {\n      buttons.forEach(function(button) {\n        button.classList.remove('active');\n      });\n\n      clicked.classList.add('active');\n    }\n\n    function setIncludedMountByKey(key, shouldScroll) {\n      let selectedButton = null;\n\n      includedMountButtons.forEach(function(button) {\n        if (button.dataset.mountKey === key) {\n          selectedButton = button;\n        }\n      });\n\n      if (!selectedButton) return;\n\n      setActive(includedMountButtons, selectedButton);\n\n      includedMountGuideCards.forEach(function(card) {\n        if (card.dataset.selectIncludedMount === key) {\n          card.classList.add('active');\n        } else {\n          card.classList.remove('active');\n        }\n      });\n\n      if (shouldScroll) {\n        const step = document.getElementById('nb-included-mount-step');\n        if (step) {\n          step.scrollIntoView({ behavior: 'smooth', block: 'start' });\n        }\n      }\n\n      updateSummary();\n    }\n\n    function updatePremiumMountStates() {\n      premiumMountRows.forEach(function(row) {\n        const qty = Number(row.querySelector('[data-premium-qty]').value || 0);\n        const key = row.dataset.premiumRow;\n        const card = document.querySelector('[data-premium-card=\"' + key + '\"]');\n\n        if (qty > 0) {\n          row.classList.add('active');\n          if (card) card.classList.add('active');\n        } else {\n          row.classList.remove('active');\n          if (card) card.classList.remove('active');\n        }\n      });\n    }\n\n    function updateAddonStates() {\n      addonInputs.forEach(function(input) {\n        const key = input.dataset.addon;\n        const row = document.querySelector('[data-addon-row=\"' + key + '\"]');\n        const card = document.querySelector('[data-toggle-addon=\"' + key + '\"]');\n\n        if (input.checked) {\n          if (row) row.classList.add('active');\n          if (card) card.classList.add('active');\n        } else {\n          if (row) row.classList.remove('active');\n          if (card) card.classList.remove('active');\n        }\n      });\n    }\n\n    function getSelectedItems() {\n      const items = [];\n      const color = getActiveColor();\n      const includedMount = getActiveIncludedMount();\n\n      if (color) {\n        items.push({\n          title: color.dataset.title,\n          variant: color.dataset.variant,\n          price: Number(color.dataset.price || 0),\n          quantity: 1,\n          included: false\n        });\n      }\n\n      if (includedMount) {\n        items.push({\n          title: includedMount.dataset.title,\n          variant: includedMount.dataset.variant,\n          price: 0,\n          quantity: 1,\n          included: true\n        });\n      }\n\n      premiumMountRows.forEach(function(row) {\n        const qty = Number(row.querySelector('[data-premium-qty]').value || 0);\n\n        if (qty > 0) {\n          items.push({\n            title: row.dataset.title,\n            variant: row.dataset.variant,\n            price: Number(row.dataset.price || 0),\n            quantity: qty,\n            included: false\n          });\n        }\n      });\n\n      addonInputs.forEach(function(input) {\n        if (input.checked) {\n          items.push({\n            title: input.dataset.title,\n            variant: input.dataset.variant,\n            price: Number(input.dataset.price || 0),\n            quantity: 1,\n            included: false\n          });\n        }\n      });\n\n      return items;\n    }\n\n    function updateSummary() {\n      const items = getSelectedItems();\n      let subtotal = 0;\n\n      summaryList.innerHTML = '';\n\n      items.forEach(function(item) {\n        subtotal += item.price * item.quantity;\n\n        const li = document.createElement('li');\n        const qtyLabel = item.quantity > 1 ? ' x' + item.quantity : '';\n        const priceLabel = item.included\n          ? '<strong class=\"included\">Included</strong>'\n          : '<strong>' + money(item.price * item.quantity) + '</strong>';\n\n        li.innerHTML = '<span>' + item.title + qtyLabel + '</span>' + priceLabel;\n        summaryList.appendChild(li);\n      });\n\n      subtotalEl.textContent = money(subtotal);\n\n      const rules = presetRules[state.preset];\n\n      if (rules && rules.discount) {\n        discountRow.style.display = 'flex';\n        discountLabel.textContent = rules.discountLabel;\n        discountValue.textContent = rules.discountValue;\n        state.discountCode = rules.discount;\n      } else {\n        discountRow.style.display = 'none';\n        state.discountCode = '';\n      }\n\n      updatePremiumMountStates();\n      updateAddonStates();\n    }\n\n    function applyPreset(presetName) {\n      const rules = presetRules[presetName];\n\n      addonInputs.forEach(function(input) {\n        input.checked = rules.addons.includes(input.dataset.addon);\n      });\n\n      state.preset = presetName;\n      updateSummary();\n    }\n\n    colorButtons.forEach(function(button) {\n      button.addEventListener('click', function() {\n        setActive(colorButtons, button);\n\n        if (button.dataset.image && mainImage) {\n          mainImage.src = button.dataset.image;\n        }\n\n        updateSummary();\n      });\n    });\n\n    includedMountButtons.forEach(function(button) {\n      button.addEventListener('click', function() {\n        setIncludedMountByKey(button.dataset.mountKey, false);\n      });\n    });\n\n    includedMountGuideCards.forEach(function(card) {\n      card.addEventListener('click', function() {\n        setIncludedMountByKey(card.dataset.selectIncludedMount, true);\n      });\n    });\n\n    presetButtons.forEach(function(button) {\n      button.addEventListener('click', function() {\n        setActive(presetButtons, button);\n        applyPreset(button.dataset.preset);\n      });\n    });\n\n    premiumMountRows.forEach(function(row) {\n      const minus = row.querySelector('[data-qty-minus]');\n      const plus = row.querySelector('[data-qty-plus]');\n      const input = row.querySelector('[data-premium-qty]');\n\n      minus.addEventListener('click', function() {\n        const current = Number(input.value || 0);\n        input.value = Math.max(0, current - 1);\n        updateSummary();\n      });\n\n      plus.addEventListener('click', function() {\n        const current = Number(input.value || 0);\n        input.value = Math.min(10, current + 1);\n        updateSummary();\n      });\n\n      input.addEventListener('change', function() {\n        let value = Number(input.value || 0);\n\n        if (value < 0) value = 0;\n        if (value > 10) value = 10;\n\n        input.value = value;\n        updateSummary();\n      });\n    });\n\n    addonInputs.forEach(function(input) {\n      input.addEventListener('change', function() {\n        updateSummary();\n      });\n    });\n\n    addonGuideCards.forEach(function(card) {\n      card.addEventListener('click', function() {\n        const key = card.dataset.toggleAddon;\n        const input = document.querySelector('[data-addon=\"' + key + '\"]');\n\n        if (!input) return;\n\n        input.checked = !input.checked;\n        updateSummary();\n      });\n    });\n\n    addToCartBtn.addEventListener('click', function() {\n      const selectedItems = getSelectedItems();\n\n      const cartItems = selectedItems\n        .filter(function(item) {\n          return item.variant && !item.variant.includes('PASTE_') && item.quantity > 0;\n        })\n        .map(function(item) {\n          return {\n            id: Number(item.variant),\n            quantity: item.quantity\n          };\n        });\n\n      if (!cartItems.length) {\n        alert('Please add valid Shopify variant IDs before testing this builder.');\n        return;\n      }\n\n      addToCartBtn.textContent = 'Adding...';\n      addToCartBtn.disabled = true;\n\n      fetch('/cart/add.js', {\n        method: 'POST',\n        headers: {\n          'Content-Type': 'application/json'\n        },\n        body: JSON.stringify({\n          items: cartItems\n        })\n      })\n      .then(function(response) {\n        if (!response.ok) {\n          throw new Error('Cart add failed');\n        }\n        return response.json();\n      })\n      .then(function() {\n        if (state.discountCode) {\n          window.location.href = '/discount/' + state.discountCode + '?redirect=/cart';\n        } else {\n          window.location.href = '/cart';\n        }\n      })\n      .catch(function(error) {\n        console.error(error);\n        alert('Something went wrong adding your setup to cart. Please try again.');\n        addToCartBtn.textContent = 'Add Setup To Cart';\n        addToCartBtn.disabled = false;\n      });\n    });\n\n    applyPreset('starter');\n    setIncludedMountByKey('flex', false);\n    updateSummary();\n  })();\n</script>",
